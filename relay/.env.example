# Copy to .env and fill in values
GEMINI_API_KEY=your_google_ai_studio_key
PORT=8080
ALLOWED_ORIGINS=https://talent-acquisition-six.vercel.app,http://localhost:3000,http://127.0.0.1:5500
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001
GEMINI_SCORE_MODEL=gemini-2.0-flash

# ── Primary save path (Vercel — always public, no ngrok/n8n needed) ──────────
PORTAL_BASE_URL=https://talent-acquisition-six.vercel.app

# ── Fallback direct Supabase save (if Vercel API unavailable) ────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key
# OR set an explicit override URL:
# LIVE_SAVE_URL=https://talent-acquisition-six.vercel.app/api/live-speech-save

# ── Optional: n8n webhook for email notifications ────────────────────────────
# Only needed for sending result emails. Not required for DB save.
# LIVE_COMPLETE_WEBHOOK=https://YOUR-NGROK.ngrok-free.dev/webhook/talent/live-speech-complete
